<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Humanitix API</label>
    <authenticationProtocol>Custom</authenticationProtocol>
    <description>Custom-header (x-api-key) authentication for the Humanitix public REST API. The API key is entered by the admin post-install in Setup; it is stored encrypted and never appears in source, Apex, or logs.</description>
    <!-- Named principal that users are granted access to via the permission set. -->
    <externalCredentialParameters>
        <parameterName>Humanitix_Named_Principal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <!-- Custom auth parameter that holds the secret API key. No <parameterValue>:
         the admin pastes the key post-install so it is stored encrypted, never in
         version control. parameterGroup ties this secret to the named principal. -->
    <externalCredentialParameters>
        <parameterName>ApiKey</parameterName>
        <parameterType>AuthParameter</parameterType>
        <parameterGroup>Humanitix_Named_Principal</parameterGroup>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
