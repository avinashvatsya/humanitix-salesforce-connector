<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Humanitix API</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <!-- Humanitix public API base host. Apex uses callout:HumanitixAPI/v1/... -->
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://api.humanitix.com</parameterValue>
    </namedCredentialParameters>
    <!-- Bind to the external credential (provides the principal + encrypted key). -->
    <namedCredentialParameters>
        <parameterName>HumanitixAuth</parameterName>
        <parameterType>Authentication</parameterType>
        <externalCredential>HumanitixAPI</externalCredential>
    </namedCredentialParameters>
    <!-- Inject the API key into the x-api-key header from the encrypted store.
         Syntax: {!$Credential.<ExternalCredentialDevName>.<ParameterName>} -->
    <namedCredentialParameters>
        <parameterName>x-api-key</parameterName>
        <parameterType>HttpHeader</parameterType>
        <parameterValue>{!$Credential.HumanitixAPI.ApiKey}</parameterValue>
    </namedCredentialParameters>
</NamedCredential>
